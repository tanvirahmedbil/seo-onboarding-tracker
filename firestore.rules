rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }
      match /activity/{activityId} {
        allow read, write: if request.auth != null;
      }
    }

    match /dmProjects/{projectId} {
      allow read, write: if request.auth != null;
      match /tasks/{taskId} {
        allow read, write: if request.auth != null;
      }
      match /activity/{activityId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
